# bash-aliases-custom
# Custom bash aliases for enhanced productivity

# Directory Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'

# Enhanced Listing Commands
alias ls='ls --color=auto --group-directories-first'
alias la='ls -A'
alias ll='ls -lh'
alias l='ls -lah'

# Safe Operations (Interactive confirmations)
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -I' # -I implies interactive for 3 or more files

# System File Information
alias df='df -h'
alias du='du -h'
alias du1='du -h --max-depth=1'
alias free='free -h'
alias ps='ps auxf'

# Network & Connectivity
alias ping='ping -c 5'
alias myip='curl -s ifconfig.me'
alias ports='sudo netstat -tulanp'
alias speedtest='curl -s https://raw.githubusercontent.com/sivel/speedtest-cli/master/speedtest.py | python3 -'

# Git Shorthands
alias gs='git status'
alias ga='git add'
alias gc='git commit -m'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias glog='git log --oneline --graph --decorate'

# Quick System Tasks
alias reload='source ~/.bashrc'
alias mkdir='mkdir -pv'
alias cpwd='pwd | xclip -selection clipboard'

# System Info Commands
alias sysinfo='neofetch'
alias cpu='lscpu | grep "Model name"'
alias mem='free -m'

# Modern Alternatives
if command -v bat >/dev/null 2>&1; then
    alias cat='bat -pp' # Plain styling
fi
if command -v fd >/dev/null 2>&1; then
    alias find='fd'
fi

# Search Utilities
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# Package Management (Debian/Ubuntu Specific)
alias update='sudo apt update && sudo apt upgrade -y'
alias install='sudo apt install'
alias remove='sudo apt remove'
alias cleanup='sudo apt autoremove -y && sudo apt clean'

# Tools
alias timer='time'
alias weather='curl -s wttr.in'