# tmux-config
# Professional tmux configuration

# General Settings
set -g default-terminal "screen-256color"
set -ga terminal-overrides ",*256col*:Tc" # True color support
set -g history-limit 20000                 
set -g base-index 1                        # Start window numbering at 1
setw -g pane-base-index 1                 # Start pane numbering at 1
set -g renumber-windows on                # Renumber windows when one is closed
set -s escape-time 0                      # Remove delay for escape key
set -g display-time 2000                  # Display tmux messages for 2 seconds

# Prefix Key
unbind C-b
set-option -g prefix C-a
bind C-a send-prefix

# Reload Configuration
bind r source-file ~/.tmux.conf \; display-message "Configuration Reloaded"

# Key Bindings (Splits)
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"
unbind '"'
unbind %

# Pane Navigation (Vim-style)
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# Pane Resizing
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# Mouse Support
set -g mouse on

# UI / Status Bar
set -g status-left-length 40
set -g status-right-length 100
set -g status-bg '#282c34' # Dark background
set -g status-fg '#abb2bf' # Light text

# Styling the active window
set-window-option -g window-status-current-style bg='#61afef',fg='#282c34',bold

# Status Left/Right elements
set -g status-left '#[fg=#98c379,bold] #S #[fg=#abb2bf]| '
set -g status-right '#[fg=#e5c07b] %Y-%m-%d %H:%M #[fg=#abb2bf]| #[fg=#c678dd]#H '

# Window Titles
set-window-option -g automatic-rename on
set-option -g set-titles on
set-option -g set-titles-string "#T - #W"
set-option -g allow-rename off

# Copy Mode (Vim keys)
setw -g mode-keys vi
bind-key -T copy-mode-vi 'v' send -X begin-selection
bind-key -T copy-mode-vi 'y' send -X copy-selection-and-cancel
